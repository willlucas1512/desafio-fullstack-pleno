# --- API ---
# Mude o JWT_SECRET para um valor longo e aleatório em produção
JWT_SECRET=
JWT_EXPIRES_IN=1h

# Credenciais do técnico (já definidas no enunciado)
TECHNICIAN_EMAIL=
TECHNICIAN_PASSWORD=

# Origens permitidas (CORS). Lista separada por vírgula.
CORS_ORIGIN=http://localhost:3000

# --- Web ---
# URL pública da API consumida pelo browser. Para deploy, troque pela
# URL pública da API (ex.: https://api.seu-dominio.com).
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Docker Compose: portas expostas no host ---
# Sobrescreva se as portas padrão estiverem ocupadas no seu ambiente.
API_HOST_PORT=3001
WEB_HOST_PORT=3000
