# defaults do docker-compose batem com o enunciado, entao `docker compose up`
# funciona sem precisar copiar esse arquivo. Use isso aqui se quiser rodar
# a API direto com Node ou sobrescrever algum valor.

PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

JWT_SECRET=
JWT_EXPIRES_IN=1h

# credenciais aceitas pela API (do enunciado)
TECHNICIAN_EMAIL=tecnico@prefeitura.rio
TECHNICIAN_PASSWORD=painel@2024

CORS_ORIGIN=http://localhost:3000
SEED_FILE=../../data/seed.json
