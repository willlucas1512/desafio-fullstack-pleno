# Copie pra .env e preencha os valores antes de subir a API.
#
#   cp apps/api/.env.example apps/api/.env
#
# O docker-compose tambem le esse arquivo (via env_file).

# --- Server ---
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# --- Auth ---
# Chave aleatoria pra assinar JWT. Gera uma com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

JWT_EXPIRES_IN=1h

# --- Credenciais do técnico ---
# Preencha com os valores documentados no enunciado do desafio
# (seção "Endpoints necessários" → "POST /auth/token").
TECHNICIAN_EMAIL=
TECHNICIAN_PASSWORD=

# --- CORS ---
# Lista separada por vírgulas. Inclua a URL do frontend em produção.
CORS_ORIGIN=http://localhost:3000

# --- Data ---
SEED_FILE=../../data/seed.json
